      "category": "负向 — 组合：name 缺失 + role 也缺失",
      "description": "多个必填字段同时缺失 — 仅返回第一条错误",
      "covers": ["NM-MISSING", "RO-MISSING", "PW-MISSING"],
      "request": {
        "phone": "13900000060"
      },
      "expectedStatus": 400,
      "expectedBody": { "message": "请填写必填字段" },
