      "covers": ["EM-DUP"],
      "precondition": "email=existing@test.com 已存在",
      "request": {
        "phone": "13999999999",
        "email": "existing@test.com",
        "password": "pass123456",
        "name": "新用户",
        "role": "landlord"
      },
      "expectedStatus": 400,
      "expectedBody": { "message": "该账号已被注册" }
