    },

    {
      "id": "REG-030",
      "category": "负向 — phone 和 email 均缺失",
      "description": "两个联系方式都不传",
      "covers": ["PH-NO-EMAIL"],
      "request": {
        "password": "pass123456",
        "name": "测试用户",
        "role": "tenant"
      },
      "expectedStatus": 400,
      "expectedBody": { "message": "手机号和邮箱至少填一个" }
    },
    {
