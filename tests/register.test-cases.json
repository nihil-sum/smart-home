{
  "$schema": "register-test-cases-v1",
  "description": "POST /api/auth/register 等价类划分测试用例 — 覆盖 phone / email / role / password / name 全部等价类",
  "endpoint": "POST /api/auth/register",
  "baseUrl": "http://localhost:3000/api",
  "validationOrder": [
    "1. password / name / role 必填 → 400 { message: '请填写必填字段' }",
    "2. role ∈ { tenant, landlord } → 400 { message: '角色无效' }",
    "3. phone 或 email 至少一个 → 400 { message: '手机号和邮箱至少填一个' }",
    "4. phone / email 不重复 → 400 { message: '该账号已被注册' }",
    "5. 全部通过 → 201 { message: '注册成功', token, user }"
  ],

  "equivalenceClasses": {
    "phone": {
      "PH-VALID":    { "class": "有效手机号",       "expect": "通过（若无其他错误）" },
      "PH-ABSENT":   { "class": "缺失/undefined",    "expect": "通过（若 email 存在）" },
      "PH-EMPTY":    { "class": "空字符串 ''",       "expect": "通过（若 email 存在）" },
      "PH-DUP":      { "class": "已注册的手机号",     "expect": "400 — 该账号已被注册" },
      "PH-NO-EMAIL": { "class": "phone 缺失 且 email 缺失", "expect": "400 — 手机号和邮箱至少填一个" }
    },
    "email": {
      "EM-VALID":    { "class": "有效邮箱",           "expect": "通过（若无其他错误）" },
      "EM-ABSENT":   { "class": "缺失/undefined",     "expect": "通过（若 phone 存在）" },
      "EM-EMPTY":    { "class": "空字符串 ''",        "expect": "通过（若 phone 存在）" },
      "EM-DUP":      { "class": "已注册的邮箱",       "expect": "400 — 该账号已被注册" }
    },
    "role": {
      "RO-TENANT":   { "class": "'tenant'",          "expect": "通过" },
      "RO-LANDLORD": { "class": "'landlord'",        "expect": "通过" },
      "RO-ADMIN":    { "class": "'admin' (非法值)",   "expect": "400 — 角色无效" },
      "RO-INVALID":  { "class": "'guest' (任意非法值)", "expect": "400 — 角色无效" },
      "RO-EMPTY":    { "class": "'' 空字符串",        "expect": "400 — 请填写必填字段 (先于角色无效检查)" },
      "RO-MISSING":  { "class": "缺失/undefined",     "expect": "400 — 请填写必填字段" }
    },
    "password": {
      "PW-NORMAL":   { "class": "≥6 字符",            "expect": "通过" },
      "PW-SHORT":    { "class": "<6 字符 (如 '12345')", "expect": "通过（后端无长度校验，但建议前端拦截）" },
      "PW-EMPTY":    { "class": "'' 空字符串",         "expect": "400 — 请填写必填字段" },
      "PW-MISSING":  { "class": "缺失/undefined",      "expect": "400 — 请填写必填字段" }
    },
    "name": {
      "NM-VALID":    { "class": "有效非空字符串",      "expect": "通过" },
      "NM-EMPTY":    { "class": "'' 空字符串",         "expect": "400 — 请填写必填字段" },
      "NM-MISSING":  { "class": "缺失/undefined",      "expect": "400 — 请填写必填字段" }
    }
  },

  "preconditions": {
    "existingUser": {
      "phone": "13800000001",
      "email": "existing@test.com",
      "password": "validPassword123",
      "name": "已存在用户",
      "role": "tenant"
    },
    "note": "测试前需在数据库中存在上述用户，用于重复性测试。种子管理员 (13800000000) 不参与注册测试。"
  },

  "testCases": [
    {
      "id": "REG-001",
      "category": "正向 — 完整字段",
      "description": "全部字段有效，phone + email 双填，角色 tenant",
      "covers": ["PH-VALID", "EM-VALID", "RO-TENANT", "PW-NORMAL", "NM-VALID"],
      "request": {
        "phone": "13900000001",
        "email": "user001@test.com",
        "password": "pass123456",
        "name": "张三",
        "role": "tenant"
      },
      "expectedStatus": 201,
      "expectedBody": {
        "message": "注册成功",
        "token": "<jwt-string>",
        "user": {
          "id": "<objectid>",
          "name": "张三",
          "role": "tenant",
          "phone": "13900000001",
          "email": "user001@test.com"
        }
      }
    },
    {
      "id": "REG-002",
      "category": "正向 — 仅 phone",
      "description": "仅 phone（无 email），角色 landlord",
      "covers": ["PH-VALID", "EM-ABSENT", "RO-LANDLORD", "PW-NORMAL", "NM-VALID"],
      "request": {
        "phone": "13900000002",
        "password": "pass123456",
        "name": "李四",
        "role": "landlord"
      },
      "expectedStatus": 201,
      "expectedBody": {
        "message": "注册成功",
        "user": {
          "name": "李四",
          "role": "landlord",
          "phone": "13900000002",
          "email": null
        }
      }
    },
    {
      "id": "REG-003",
      "category": "正向 — 仅 email",
      "description": "仅 email（无 phone），角色 tenant",
      "covers": ["PH-ABSENT", "EM-VALID", "RO-TENANT", "PW-NORMAL", "NM-VALID"],
      "request": {
        "email": "user003@test.com",
        "password": "pass123456",
        "name": "王五",
        "role": "tenant"
      },
      "expectedStatus": 201,
      "expectedBody": {
        "message": "注册成功",
        "user": {
          "name": "王五",
          "role": "tenant",
          "phone": null,
          "email": "user003@test.com"
        }
      }
    },
    {
      "id": "REG-004",
      "category": "正向 — phone 空字符串 + email 有效",
      "description": "phone 传 ''，email 有效 — phone 应转为 undefined (不存空串)",
      "covers": ["PH-EMPTY", "EM-VALID", "RO-TENANT", "PW-NORMAL", "NM-VALID"],
      "request": {
        "phone": "",
        "email": "user004@test.com",
        "password": "pass123456",
        "name": "赵六",
        "role": "tenant"
      },
      "expectedStatus": 201,
      "expectedBody": {
        "message": "注册成功",
        "user": {
          "phone": null,
          "email": "user004@test.com"
        }
      }
    },
    {
      "id": "REG-005",
      "category": "正向 — email 空字符串 + phone 有效",
      "description": "email 传 ''，phone 有效",
      "covers": ["PH-VALID", "EM-EMPTY", "RO-LANDLORD", "PW-NORMAL", "NM-VALID"],
      "request": {
        "phone": "13900000003",
        "email": "",
        "password": "pass123456",
        "name": "孙七",
        "role": "landlord"
      },
      "expectedStatus": 201,
      "expectedBody": {
        "message": "注册成功",
        "user": {
          "phone": "13900000003",
          "email": null
        }
      }
    },
    {
      "id": "REG-006",
      "category": "正向 — 密码边界（6 字符）",
      "description": "密码恰好 6 字符，验证最短密码可通过",
      "covers": ["PH-VALID", "EM-VALID", "RO-TENANT", "PW-NORMAL", "NM-VALID"],
      "request": {
        "phone": "13900000004",
        "email": "user006@test.com",
        "password": "123456",
        "name": "周六",
        "role": "tenant"
      },
      "expectedStatus": 201,
      "note": "后端无密码长度校验，6 字符可通过。若前端有 ≥6 的校验则此为边界值。"
    },

    {
      "id": "REG-010",
      "category": "负向 — password 缺失",
      "description": "password 字段完全缺失",
      "covers": ["PW-MISSING"],
      "request": {
        "phone": "13900000010",
        "name": "测试用户",
        "role": "tenant"
      },
      "expectedStatus": 400,
      "expectedBody": { "message": "请填写必填字段" }
    },
    {
      "id": "REG-011",
      "category": "负向 — password 为 null",
      "description": "password 传 null",
      "covers": ["PW-MISSING"],
      "request": {
        "phone": "13900000011",
        "password": null,
        "name": "测试用户",
        "role": "tenant"
      },
      "expectedStatus": 400,
      "expectedBody": { "message": "请填写必填字段" }
    },
    {
      "id": "REG-012",
      "category": "负向 — password 为空字符串",
      "description": "password 传 ''",
      "covers": ["PW-EMPTY"],
      "request": {
        "phone": "13900000012",
        "password": "",
        "name": "测试用户",
        "role": "tenant"
      },
      "expectedStatus": 400,
      "expectedBody": { "message": "请填写必填字段" }
    },
    {
      "id": "REG-013",
      "category": "负向 — name 缺失",
      "description": "name 字段完全缺失",
      "covers": ["NM-MISSING"],
      "request": {
        "phone": "13900000013",
        "password": "pass123456",
        "role": "tenant"
      },
      "expectedStatus": 400,
      "expectedBody": { "message": "请填写必填字段" }
    },
    {
      "id": "REG-014",
      "category": "负向 — name 为 null",
      "description": "name 传 null",
      "covers": ["NM-MISSING"],
      "request": {
        "phone": "13900000014",
        "password": "pass123456",
        "name": null,
        "role": "tenant"
      },
      "expectedStatus": 400,
      "expectedBody": { "message": "请填写必填字段" }
    },
    {
      "id": "REG-015",
      "category": "负向 — name 为空字符串",
      "description": "name 传 ''",
      "covers": ["NM-EMPTY"],
      "request": {
        "phone": "13900000015",
        "password": "pass123456",
        "name": "",
        "role": "tenant"
      },
      "expectedStatus": 400,
      "expectedBody": { "message": "请填写必填字段" }
    },
    {
      "id": "REG-016",
      "category": "负向 — role 缺失",
      "description": "role 字段完全缺失",
      "covers": ["RO-MISSING"],
      "request": {
        "phone": "13900000016",
        "password": "pass123456",
        "name": "测试用户"
      },
      "expectedStatus": 400,
      "expectedBody": { "message": "请填写必填字段" }
    },
    {
      "id": "REG-017",
      "category": "负向 — role 为 null",
      "description": "role 传 null",
      "covers": ["RO-MISSING"],
      "request": {
        "phone": "13900000017",
        "password": "pass123456",
        "name": "测试用户",
