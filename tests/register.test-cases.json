      "expectedBody": { "message": "手机号和邮箱至少填一个" }
    },
    {
      "id": "REG-033",
      "category": "负向 — phone undefined + email ''",
      "description": "phone 不传 + email 空串",
      "covers": ["PH-NO-EMAIL"],
      "request": {
        "email": "",
        "password": "pass123456",
        "name": "测试用户",
        "role": "tenant"
      },
      "expectedStatus": 400,
      "expectedBody": { "message": "手机号和邮箱至少填一个" }
    },

    {
      "id": "REG-040",
      "category": "负向 — phone 重复",
      "description": "使用已注册用户的 phone（不传 email），预期返回重复错误",
      "covers": ["PH-DUP"],
      "precondition": "需先在数据库中存在 phone=13800000001 的用户（见 preconditions）",
      "request": {
        "phone": "13800000001",
        "password": "pass123456",
        "name": "新用户",
        "role": "tenant"
      },
      "expectedStatus": 400,
      "expectedBody": { "message": "该账号已被注册" }
    },
    {
      "id": "REG-041",
      "category": "负向 — email 重复",
      "description": "使用已注册用户的 email（不传 phone），预期返回重复错误",
      "covers": ["EM-DUP"],
      "precondition": "需先在数据库中存在 email=existing@test.com 的用户（见 preconditions）",
      "request": {
        "email": "existing@test.com",
        "password": "pass123456",
        "name": "新用户",
        "role": "landlord"
      },
      "expectedStatus": 400,
      "expectedBody": { "message": "该账号已被注册" }
    },
    {
      "id": "REG-042",
      "category": "负向 — phone 重复 + email 新",
      "description": "phone 重复但 email 是新的 — phone 先检查，命中重复",
      "covers": ["PH-DUP"],
      "precondition": "phone=13800000001 已存在",
      "request": {
        "phone": "13800000001",
        "email": "newemail@test.com",
        "password": "pass123456",
        "name": "新用户",
        "role": "tenant"
