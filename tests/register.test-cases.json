    },
    {
      "id": "REG-022",
      "category": "负向 — role = LANDLORD（全大写）",
      "description": "role 传 'LANDLORD' — 精确匹配，不在枚举中",
      "covers": ["RO-INVALID"],
      "request": {
        "phone": "13900000022",
        "password": "pass123456",
        "name": "测试用户",
