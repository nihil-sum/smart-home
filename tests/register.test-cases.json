    },
    {
      "id": "REG-018",
      "category": "负向 — role 为空字符串",
      "description": "role 传 '' — 先被 !role 捕获，返回 '请填写必填字段' 而非 '角色无效'",
      "covers": ["RO-EMPTY"],
      "request": {
        "phone": "13900000018",
        "password": "pass123456",
        "name": "测试用户",
        "role": ""
      },
      "expectedStatus": 400,
      "expectedBody": { "message": "请填写必填字段" },
      "validationNote": "空字符串被 !role 拦截（falsy），不会到达角色枚举检查"
    },
    {
      "id": "REG-019",
      "category": "负向 — role = admin",
      "description": "role 传 'admin' — 不在允许列表中",
      "covers": ["RO-ADMIN"],
      "request": {
        "phone": "13900000019",
        "password": "pass123456",
        "name": "测试用户",
        "role": "admin"
      },
      "expectedStatus": 400,
      "expectedBody": { "message": "角色无效" }
    },
    {
      "id": "REG-020",
      "category": "负向 — role = guest（任意非法值）",
      "description": "role 传不在枚举中的任意值 'guest'",
      "covers": ["RO-INVALID"],
      "request": {
        "phone": "13900000020",
        "password": "pass123456",
        "name": "测试用户",
        "role": "guest"
      },
      "expectedStatus": 400,
      "expectedBody": { "message": "角色无效" }
    },
    {
      "id": "REG-021",
      "category": "负向 — role 大小写变体",
      "description": "role 传 'Tenant' (首字母大写) — 精确匹配，不在枚举中",
      "covers": ["RO-INVALID"],
      "request": {
        "phone": "13900000021",
        "password": "pass123456",
        "name": "测试用户",
        "role": "Tenant"
      },
      "expectedStatus": 400,
      "expectedBody": { "message": "角色无效" },
