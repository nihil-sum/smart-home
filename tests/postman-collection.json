              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"houseId\": \"{{houseId}}\",\n  \"visitDate\": \"2026-07-10\",\n  \"visitTime\": \"14:00\",\n  \"contact\": \"13800000000\",\n  \"remark\": \"下班后看房\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/appointments",
              "host": ["{{baseUrl}}"],
              "path": ["appointments"]
            }
          },
          "response": []
        },
        {
          "name": "PUT 确认预约（房东）",
          "request": {
            "method": "PUT",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/appointments/{{appointmentId}}/confirm",
              "host": ["{{baseUrl}}"],
              "path": ["appointments", "{{appointmentId}}", "confirm"]
            },
            "description": "仅 pending → confirmed，需房东本人"
          },
          "response": []
        },
        {
          "name": "PUT 拒绝预约（房东）",
          "request": {
            "method": "PUT",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reason\": \"时间冲突，无法安排\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/appointments/{{appointmentId}}/reject",
              "host": ["{{baseUrl}}"],
              "path": ["appointments", "{{appointmentId}}", "reject"]
            },
            "description": "仅 pending → rejected，需房东本人"
          },
          "response": []
        },
        {
          "name": "PUT 取消预约（租客）",
          "request": {
            "method": "PUT",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/appointments/{{appointmentId}}/cancel",
              "host": ["{{baseUrl}}"],
              "path": ["appointments", "{{appointmentId}}", "cancel"]
            },
            "description": "仅 pending → cancelled，需租客本人"
          },
          "response": []
        }
      ]
    },
